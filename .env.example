# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/crednxt

# Security Keys
JWT_SECRET=your-super-secret-jwt-key-here-at-least-64-characters-long
SESSION_SECRET=your-super-secret-session-key-here-at-least-64-characters-long

# Server Configuration
PORT=5000
NODE_ENV=development

# Payment Processing (Optional)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# SMS Notifications (Optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# File Storage (Optional)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_BUCKET_NAME=your_s3_bucket_name_here
AWS_REGION=us-east-1

# External APIs (Optional)
UPI_GATEWAY_URL=https://api.upi-gateway.com
UPI_MERCHANT_ID=your_merchant_id_here
UPI_API_KEY=your_upi_api_key_here

# Security Configuration
BCRYPT_ROUNDS=12
TOKEN_EXPIRY=7d
OTP_EXPIRY=10m

# Development Only
DEBUG=true
LOG_LEVEL=debug

# Production Only (uncomment for production)
# NODE_ENV=production
# SECURE_COOKIES=true
# TRUST_PROXY=true