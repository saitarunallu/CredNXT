# CredNXT Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/crednxt
PGHOST=localhost
PGPORT=5432
PGDATABASE=crednxt
PGUSER=username
PGPASSWORD=password

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Secret for token signing (REQUIRED - generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Refresh Token Secret (REQUIRED - different from JWT_SECRET)
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-too

# Session Secret for Express sessions (REQUIRED)
SESSION_SECRET=your-session-secret-for-express-sessions

# Token Expiration Times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Environment (development, staging, production)
NODE_ENV=development

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Application URL (for callbacks and redirects)
APP_URL=http://localhost:5000

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
# Email Service Configuration
EMAIL_SERVICE_PROVIDER=sendgrid
EMAIL_SERVICE_API_KEY=your-sendgrid-api-key
EMAIL_FROM_ADDRESS=noreply@crednxt.com
EMAIL_FROM_NAME=CredNXT

# SMS Service Configuration
SMS_SERVICE_PROVIDER=twilio
SMS_SERVICE_ACCOUNT_SID=your-twilio-account-sid
SMS_SERVICE_AUTH_TOKEN=your-twilio-auth-token
SMS_SERVICE_PHONE_NUMBER=+1234567890

# Push Notification Service
PUSH_SERVICE_API_KEY=your-push-service-api-key

# =============================================================================
# PAYMENT GATEWAY (Optional)
# =============================================================================
# UPI Payment Gateway
UPI_GATEWAY_API_KEY=your-upi-gateway-api-key
UPI_GATEWAY_SECRET=your-upi-gateway-secret
UPI_GATEWAY_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# FILE STORAGE (Optional)
# =============================================================================
# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=crednxt-documents

# Local Storage Path (fallback)
UPLOAD_PATH=./uploads

# =============================================================================
# MONITORING & LOGGING (Optional)
# =============================================================================
# Application Insights / Monitoring
MONITORING_API_KEY=your-monitoring-service-api-key

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Sentry for Error Tracking
SENTRY_DSN=your-sentry-dsn

# =============================================================================
# RATE LIMITING & SECURITY
# =============================================================================
# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Security Headers
ENABLE_HELMET=true
ENABLE_CORS=true

# =============================================================================
# CACHE CONFIGURATION (Optional)
# =============================================================================
# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Cache TTL (Time To Live) in seconds
CACHE_TTL=3600

# =============================================================================
# NOTIFICATION PREFERENCES
# =============================================================================
# Default notification channels
DEFAULT_EMAIL_NOTIFICATIONS=true
DEFAULT_SMS_NOTIFICATIONS=false
DEFAULT_PUSH_NOTIFICATIONS=true

# Notification timing
REMINDER_DAYS_BEFORE_DUE=3
OVERDUE_REMINDER_FREQUENCY_HOURS=24

# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================
# Interest rate limits (percentage)
MIN_INTEREST_RATE=0
MAX_INTEREST_RATE=36

# Loan amount limits (in rupees)
MIN_LOAN_AMOUNT=1000
MAX_LOAN_AMOUNT=10000000

# Loan tenure limits (in months)
MIN_LOAN_TENURE=1
MAX_LOAN_TENURE=60

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================
# Enable/disable features
ENABLE_EMAIL_VERIFICATION=true
ENABLE_SMS_VERIFICATION=false
ENABLE_DOCUMENT_UPLOAD=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_PAYMENT_GATEWAY=false

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Test Database (for running tests)
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/crednxt_test

# Debug Configuration
DEBUG_SQL=false
DEBUG_ROUTES=false

# Mock Services (for development)
MOCK_EMAIL_SERVICE=true
MOCK_SMS_SERVICE=true
MOCK_PAYMENT_GATEWAY=true

# =============================================================================
# PRODUCTION SPECIFIC
# =============================================================================
# SSL/TLS Configuration
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/private.key

# Cluster Configuration
CLUSTER_WORKERS=auto

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_INTERVAL=30000

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit this file with actual secrets to version control
# 2. Generate strong, unique secrets for production environments
# 3. Use environment-specific values for different deployment stages
# 4. Consider using a secret management service for production
# 5. Validate all environment variables on application startup