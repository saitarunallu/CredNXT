# CredNXT P2P Lending Platform - Environment Configuration Template
# Copy this file to .env.production for production deployment

# ==== REQUIRED ENVIRONMENT VARIABLES ====
# These must be set for the application to function

# Application Environment
NODE_ENV=production
PORT=5000

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database_name
PGHOST=your-rds-endpoint.region.rds.amazonaws.com
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-secure-database-password
PGDATABASE=crednxt

# Authentication & Security Secrets
JWT_SECRET=your-super-secure-jwt-secret-at-least-32-characters-long
SESSION_SECRET=your-super-secure-session-secret-at-least-32-characters-long

# ==== OPTIONAL ENVIRONMENT VARIABLES ====
# These have sensible defaults but can be customized

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-aws-account-id

# Banking & Compliance
AUDIT_ENABLED=true
COMPLIANCE_ENABLED=true
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data

# Security & Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=https://your-domain.com
HELMET_ENABLED=true

# Logging & Monitoring
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn-for-error-tracking
METRICS_ENABLED=true

# Health Checks & Monitoring
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT=5000

# External Services (Optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid-for-sms
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# File Storage (Optional)
S3_BUCKET=your-s3-bucket-for-documents
S3_REGION=us-east-1

# ==== DEVELOPMENT OVERRIDES ====
# For development environment, you can override these

# Database (Development)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/crednxt_dev

# Security (Development - Less Strict)
# JWT_SECRET=development-jwt-secret-not-for-production
# SESSION_SECRET=development-session-secret-not-for-production

# Logging (Development)
# LOG_LEVEL=debug
# NODE_ENV=development

# ==== SECURITY NOTES ====
# 1. Never commit this file with real values to version control
# 2. Use strong, randomly generated secrets for production
# 3. Rotate secrets regularly
# 4. Use AWS Secrets Manager or Parameter Store for production secrets
# 5. Ensure DATABASE_URL includes SSL parameters for production: ?sslmode=require