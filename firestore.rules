rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Loan offers - users can read offers made to them or by them
    match /offers/{offerId} {
      allow read, write: if request.auth != null && 
        (resource.data.lenderId == request.auth.uid || 
         resource.data.borrowerId == request.auth.uid);
    }
    
    // Payments - users can access payments they are involved in
    match /payments/{paymentId} {
      allow read, write: if request.auth != null && 
        (resource.data.payerId == request.auth.uid || 
         resource.data.payeeId == request.auth.uid);
    }
    
    // Notifications - users can only see their own notifications
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }
    
    // SMS messages - admin only (for logging)
    match /sms_messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    
    // Audit logs - admin only
    match /audit/{auditId} {
      allow read: if request.auth != null;
      allow write: if false; // Only server can write audit logs
    }
  }
}